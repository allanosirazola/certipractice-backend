# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/certification_db?schema=public"

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Bcrypt Configuration
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
# Comma-separated allowed frontend origins (production domains are also always
# allowed in code). Example:
#   ALLOWED_ORIGINS=https://certipractice.com,https://www.certipractice.com

# Public site URL used to build links in emails (verification, etc.)
FRONTEND_URL=https://certipractice.com

# ─── Email (SMTP) ──────────────────────────────────────────────────────────
# When SMTP_HOST is set, the app sends real emails (nodemailer). Otherwise it
# logs the email to stdout (dev fallback). Works with any SMTP provider; below
# is the free-tier Resend setup (resend.com — 3,000 emails/month):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASSWORD=re_xxxxxxxxxxxx   # Resend API key (set in Railway, never commit)
#   SMTP_FROM=CertiPractice <noreply@certipractice.com>
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CertiPractice <noreply@certipractice.com>

# Logging
LOG_LEVEL=debug

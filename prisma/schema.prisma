// Prisma Schema for Certification Exam System
// This schema represents the database structure for managing certification exams

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  firstName     String?   @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  role          UserRole  @default(student)
  isActive      Boolean   @default(true) @map("is_active")
  isValidated   Boolean   @default(false) @map("is_validated")
  // Email-verification state. emailVerified=true means the user clicked the
  // link sent to their inbox; defaults to true for existing rows via the
  // backfill in the migration. New registrations land at false.
  emailVerified            Boolean   @default(true)  @map("email_verified")
  emailVerificationToken   String?   @map("email_verification_token") @db.VarChar(128)
  emailVerificationExpires DateTime? @map("email_verification_expires")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  exams             Exam[]
  createdQuestions  Question[]       @relation("QuestionCreator")
  reviewedQuestions Question[]       @relation("QuestionReviewer")
  questionReports   QuestionReport[]
  bookmarks         Bookmark[]
  questionNotes     QuestionNote[]
  questionReviews   QuestionReview[]
  dailyQuizCompletions DailyQuizCompletion[]
  studyPlans        StudyPlan[]
  studyPlans        StudyPlan[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([emailVerificationToken])
  @@map("users")
}

enum UserRole {
  admin
  instructor
  student
}

// ============================================================================
// CERTIFICATION STRUCTURE
// ============================================================================

model Provider {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  code        String   @unique @db.VarChar(20)
  description String?  @db.Text
  logoUrl     String?  @map("logo_url") @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  certifications Certification[]

  @@map("providers")
}

model Certification {
  id          Int      @id @default(autoincrement())
  providerId  Int      @map("provider_id")
  name        String   @db.VarChar(200)
  code        String   @unique @db.VarChar(50)
  description String?  @db.Text
  difficulty  String   @default("medium") @db.VarChar(20)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  topics   Topic[]
  exams    Exam[]
  studyPlans StudyPlan[]

  @@unique([providerId, code])
  @@index([providerId])
  @@map("certifications")
}

model Topic {
  id              Int      @id @default(autoincrement())
  certificationId Int      @map("certification_id")
  name            String   @db.VarChar(200)
  description     String?  @db.Text
  orderIndex      Int      @default(0) @map("order_index")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  questions     Question[]

  @@unique([certificationId, name])
  @@index([certificationId])
  @@map("topics")
}

// ============================================================================
// QUESTIONS
// ============================================================================

model QuestionType {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  questions Question[]

  @@map("question_types")
}

model Question {
  id               String         @id @default(uuid()) @db.Uuid
  topicId          Int            @map("topic_id")
  questionTypeId   Int            @map("question_type_id")
  questionText     String         @map("question_text") @db.Text
  explanation      String?        @db.Text
  difficulty       Difficulty     @default(medium)
  points           Int            @default(1)
  timeEstimate     Int?           @map("time_estimate") // seconds
  tags             String[]       @default([])
  contentHash      String         @unique @map("content_hash") @db.VarChar(64)
  metadata         Json           @default("{}")
  reviewStatus     ReviewStatus   @default(pending) @map("review_status")
  reviewedById     Int?           @map("reviewed_by")
  reviewedAt       DateTime?      @map("reviewed_at")
  reviewNotes      String?        @map("review_notes") @db.Text
  createdById      Int?           @map("created_by")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  topic        Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questionType QuestionType       @relation(fields: [questionTypeId], references: [id])
  createdBy    User?              @relation("QuestionCreator", fields: [createdById], references: [id])
  reviewedBy   User?              @relation("QuestionReviewer", fields: [reviewedById], references: [id])
  options      QuestionOption[]
  statistics   QuestionStatistics?
  reports      QuestionReport[]
  examAnswers  ExamAnswer[]
  bookmarks    Bookmark[]
  notes        QuestionNote[]
  reviews      QuestionReview[]

  @@index([topicId])
  @@index([questionTypeId])
  @@index([difficulty])
  @@index([reviewStatus])
  @@index([contentHash])
  @@index([tags], type: Gin)
  @@map("questions")
}

model QuestionOption {
  id          String   @id @default(uuid()) @db.Uuid
  questionId  String   @map("question_id") @db.Uuid
  optionLabel String   @map("option_label") @db.VarChar(5)
  optionText  String   @map("option_text") @db.Text
  isCorrect   Boolean  @default(false) @map("is_correct")
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, optionLabel])
  @@index([questionId])
  @@map("question_options")
}

model QuestionStatistics {
  questionId        String    @id @map("question_id") @db.Uuid
  totalAttempts     Int       @default(0) @map("total_attempts")
  correctAttempts   Int       @default(0) @map("correct_attempts")
  averageTimeSeconds Int      @default(0) @map("average_time_seconds")
  lastAttemptedAt   DateTime? @map("last_attempted_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_statistics")
}

model QuestionReport {
  id          Int          @id @default(autoincrement())
  questionId  String       @map("question_id") @db.Uuid
  userId      Int          @map("user_id")
  reportType  ReportType   @map("report_type")
  description String       @db.Text
  status      ReportStatus @default(pending)
  resolvedAt  DateTime?    @map("resolved_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  // Relations
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([questionId])
  @@index([userId])
  @@index([status])
  @@map("question_reports")
}

enum Difficulty {
  easy
  medium
  hard
  expert
}

enum ReviewStatus {
  pending
  approved
  rejected
  needs_revision
}

enum ReportType {
  incorrect_answer
  unclear_question
  outdated_content
  typo
  other
}

enum ReportStatus {
  pending
  reviewed
  resolved
  dismissed
}

// ============================================================================
// USER ENGAGEMENT (bookmarks + personal notes)
// ============================================================================

/// User-saved question for later review.
/// Acts like a "favorite": one row per (user, question) pair.
model Bookmark {
  id         BigInt   @id @default(autoincrement())
  userId     Int      @map("user_id")
  questionId String   @map("question_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, createdAt])
  @@index([questionId])
  @@map("bookmarks")
}

/// Free-form personal note attached to a question.
/// One note per (user, question) — UPSERT pattern.
model QuestionNote {
  id         BigInt   @id @default(autoincrement())
  userId     Int      @map("user_id")
  questionId String   @map("question_id") @db.Uuid
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, updatedAt])
  @@index([questionId])
  @@map("question_notes")
}

/// Spaced-repetition review state (SM-2 algorithm).
///
/// One row per (user, question). Created lazily the first time a user
/// answers a question (correctly or not) in any mode. The next time the
/// item is due, the FlashcardMode UI surfaces it.
///
/// SM-2 quality grades (matches how Anki / SuperMemo call them):
///   0  again  → reset interval to 1 day, drop ease
///   1  hard   → reduce ease, shorter interval
///   2  good   → keep ease, normal interval
///   3  easy   → bump ease, longer interval
model QuestionReview {
  id            BigInt   @id @default(autoincrement())
  userId        Int      @map("user_id")
  questionId    String   @map("question_id") @db.Uuid

  /// Ease factor (SM-2). Starts at 2.5, clamped to [1.3, 3.0].
  easeFactor    Float    @default(2.5) @map("ease_factor")
  /// Current scheduling interval in days. 0 for a freshly-introduced card.
  intervalDays  Int      @default(0)   @map("interval_days")
  /// Successful (good/easy) graduations in a row. Resets to 0 on "again".
  repetitions   Int      @default(0)
  /// Total times this card has been graded (any quality).
  lapses        Int      @default(0)
  /// When the card is next eligible for review (UTC midnight aligned).
  dueAt         DateTime @default(now()) @map("due_at")
  /// Timestamp of the most recent grading.
  lastReviewedAt DateTime? @map("last_reviewed_at")
  /// Quality of the most recent grading (0..3).
  lastQuality   Int?      @map("last_quality")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, dueAt])
  @@index([userId, lastReviewedAt])
  @@index([questionId])
  @@map("question_reviews")
}

// ============================================================================
// EXAMS
// ============================================================================

model Exam {
  id              String     @id @default(uuid()) @db.Uuid
  userId          Int?       @map("user_id")
  sessionId       String?    @map("session_id") @db.VarChar(100) // For anonymous users
  certificationId Int        @map("certification_id")
  title           String     @db.VarChar(255)
  description     String?    @db.Text
  mode            ExamMode   @default(practice)
  questionCount   Int        @map("question_count")
  timeLimit       Int        @map("time_limit") // minutes
  passingScore    Decimal    @default(70) @map("passing_score") @db.Decimal(5, 2)
  status          ExamStatus @default(pending)
  score           Decimal?   @db.Decimal(5, 2)
  passed          Boolean?
  currentIndex    Int        @default(0) @map("current_index")
  settings        Json       @default("{}")
  startedAt       DateTime?  @map("started_at")
  completedAt     DateTime?  @map("completed_at")
  pausedAt        DateTime?  @map("paused_at")
  totalPausedTime Int        @default(0) @map("total_paused_time") // seconds
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  user          User?         @relation(fields: [userId], references: [id])
  certification Certification @relation(fields: [certificationId], references: [id])
  answers       ExamAnswer[]

  @@index([userId])
  @@index([sessionId])
  @@index([certificationId])
  @@index([status])
  @@index([createdAt])
  @@map("exams")
}

model ExamAnswer {
  id           String    @id @default(uuid()) @db.Uuid
  examId       String    @map("exam_id") @db.Uuid
  questionId   String    @map("question_id") @db.Uuid
  orderIndex   Int       @map("order_index")
  userAnswer   Json?     @map("user_answer") // Array of selected option indices
  isCorrect    Boolean?  @map("is_correct")
  timeSpent    Int       @default(0) @map("time_spent") // seconds
  flagged      Boolean   @default(false)
  answeredAt   DateTime? @map("answered_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([examId, questionId])
  @@index([examId])
  @@index([questionId])
  @@map("exam_answers")
}

enum ExamMode {
  practice
  timed
  review
  simulation
}

enum ExamStatus {
  pending
  active
  paused
  completed
  abandoned
}

// ============================================================================
// ADDITIONAL TABLES FOR FUTURE FEATURES
// ============================================================================

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.VarChar(100)
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// TELEMETRY / ANALYTICS TABLES
// ============================================================================
// Dedicated tables for high-volume analytics events.
// Designed for time-series queries with appropriate indexes.
// Anonymous users are tracked via sessionId (UUID v4).

/// Tracks every exam lifecycle event: created, started, paused, resumed,
/// completed, abandoned, cancelled. Allows reconstructing the full timeline
/// of any exam attempt.
model ExamEvent {
  id         BigInt           @id @default(autoincrement())
  examId     String           @map("exam_id") @db.Uuid
  userId     Int?             @map("user_id")
  sessionId  String?          @map("session_id") @db.VarChar(64)
  eventType  ExamEventType    @map("event_type")
  /// Free-form metadata: questionCount, mode, score, timeSpent, reason, etc.
  metadata   Json?
  /// Where the user was at the moment (which question index)
  questionIndex Int?          @map("question_index")
  ipAddress  String?          @map("ip_address") @db.VarChar(45)
  userAgent  String?          @map("user_agent") @db.VarChar(500)
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([examId])
  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt])
  @@map("exam_events")
}

enum ExamEventType {
  exam_created
  exam_started
  exam_paused
  exam_resumed
  exam_completed
  exam_abandoned
  exam_cancelled
  exam_answer_submitted
  exam_question_flagged
  exam_question_unflagged
  exam_question_viewed
  exam_navigated
}

/// Tracks individual interactions with questions outside of exam context
/// (random practice, search, browse, mark/unmark, report).
model QuestionEvent {
  id          BigInt              @id @default(autoincrement())
  questionId  String              @map("question_id") @db.Uuid
  userId      Int?                @map("user_id")
  sessionId   String?             @map("session_id") @db.VarChar(64)
  eventType   QuestionEventType   @map("event_type")
  /// For 'answered' events: was the answer correct?
  isCorrect   Boolean?            @map("is_correct")
  /// Time the user spent on this question in seconds
  timeSpent   Int?                @map("time_spent")
  /// Optional context: examId, source page, search query
  metadata    Json?
  ipAddress   String?             @map("ip_address") @db.VarChar(45)
  createdAt   DateTime            @default(now()) @map("created_at")

  @@index([questionId, createdAt])
  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([eventType, createdAt])
  @@index([questionId, isCorrect])
  @@index([createdAt])
  @@map("question_events")
}

enum QuestionEventType {
  viewed
  answered
  reported
  bookmarked
  unbookmarked
  reviewed
}

/// Generic user activity log: logins, logouts, page views, searches.
/// Use sparingly for cross-cutting events not covered by ExamEvent or QuestionEvent.
model UserActivity {
  id          BigInt           @id @default(autoincrement())
  userId      Int?             @map("user_id")
  sessionId   String?          @map("session_id") @db.VarChar(64)
  activityType UserActivityType @map("activity_type")
  /// Page path or referrer for navigation events
  path        String?          @db.VarChar(500)
  referrer    String?          @db.VarChar(500)
  /// Free-form metadata
  metadata    Json?
  /// Duration in milliseconds (for sessions, page views)
  durationMs  Int?             @map("duration_ms")
  ipAddress   String?          @map("ip_address") @db.VarChar(45)
  userAgent   String?          @map("user_agent") @db.VarChar(500)
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([activityType, createdAt])
  @@index([createdAt])
  @@map("user_activity")
}

enum UserActivityType {
  login
  logout
  registration
  page_view
  search
  navigation
  session_start
  session_end
  feature_used
  error_encountered
}

/// Pre-aggregated daily metrics for fast dashboard loading.
/// Populated by a scheduled job (or recomputed on-demand).
/// One row per day per metric category.
model DailyMetrics {
  id              BigInt   @id @default(autoincrement())
  /// Date in YYYY-MM-DD (00:00:00 UTC)
  date            DateTime @db.Date
  /// Optional partition: 'global', 'cert:<id>', 'provider:<name>'
  scope           String   @default("global") @db.VarChar(100)

  // Exam metrics
  examsCreated      Int @default(0) @map("exams_created")
  examsStarted      Int @default(0) @map("exams_started")
  examsCompleted    Int @default(0) @map("exams_completed")
  examsAbandoned    Int @default(0) @map("exams_abandoned")
  examsPassed       Int @default(0) @map("exams_passed")
  /// Average score among completed exams (0-100)
  averageScore      Float? @map("average_score")
  /// Average time spent per completed exam, in seconds
  averageTimeSpent  Int?   @map("average_time_spent")

  // Question metrics
  questionsViewed     Int @default(0) @map("questions_viewed")
  questionsAnswered   Int @default(0) @map("questions_answered")
  questionsCorrect    Int @default(0) @map("questions_correct")
  questionsReported   Int @default(0) @map("questions_reported")

  // User metrics
  uniqueUsers       Int @default(0) @map("unique_users")
  uniqueSessions    Int @default(0) @map("unique_sessions")
  newUsers          Int @default(0) @map("new_users")
  logins            Int @default(0) @map("logins")
  pageViews         Int @default(0) @map("page_views")

  computedAt        DateTime @default(now()) @map("computed_at")

  @@unique([date, scope])
  @@index([date])
  @@index([scope, date])
  @@map("daily_metrics")
}

/// Daily-quiz completion record.
///
/// One row per (user, quiz_date). Created when a user submits their
/// 5-question daily quiz. Anonymous users don't write here — their
/// completion is tracked client-side via localStorage only.
///
/// Doubles as the streak source of truth for the daily-quiz cadence
/// (separate from generic activity streaks).
model DailyQuizCompletion {
  id          BigInt   @id @default(autoincrement())
  userId      Int      @map("user_id")
  /// The quiz date in UTC, normalized to midnight (YYYY-MM-DD).
  /// Unique per user so the same day can't be submitted twice.
  quizDate    DateTime @map("quiz_date") @db.Date
  /// 0..5 — number of correctly-answered questions in this run.
  score       Int
  /// Total questions in the quiz (defensive; should always be 5 today).
  total       Int      @default(5)
  /// Question IDs presented (JSON array). Lets us audit the selection
  /// algorithm and prevent re-selecting same questions next day.
  questionIds Json     @map("question_ids")
  completedAt DateTime @default(now()) @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizDate])
  @@index([userId, quizDate])
  @@map("daily_quiz_completions")
}

/// User-defined study plan toward a target certification date.
///
/// Active state lives in `isActive` rather than a separate "current"
/// flag — a user can have multiple plans (one per certification) but
/// only one active per (user, certification). On creation we soft-
/// deactivate previous plans for the same (user, certification).
///
/// daily_goal is computed at creation time from days_remaining and a
/// readiness-aware target. We don't recompute on the fly — the user
/// agreed to N questions/day, that's the contract.
model StudyPlan {
  id              BigInt   @id @default(autoincrement())
  userId          Int      @map("user_id")
  certificationId Int      @map("certification_id")
  targetDate      DateTime @map("target_date") @db.Date
  dailyGoal       Int      @map("daily_goal")
  /// Total questions answered since plan creation (for progress UI).
  /// Updated by a periodic sweep or on-demand in getActivePlan().
  questionsAnswered Int    @default(0) @map("questions_answered")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, certificationId])
  @@map("study_plans")
}

/// Study plan toward a specific exam date.
///
/// One active plan per (user, certification) at a time. The plan is the
/// user's commitment ("I want to be ready by July 1st, 30 min/day"); the
/// service computes daily targets, on-track status, and adjusts when the
/// user falls behind. Past plans are kept for history.
model StudyPlan {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  certificationId Int      @map("certification_id")
  /// Target date for the real exam. Comparisons use UTC midnight.
  examDate        DateTime @map("exam_date") @db.Date
  /// Self-set effort budget (10..240). The service uses this to decide
  /// how many questions to suggest per day rather than a hard cap.
  dailyMinutes    Int      @default(20) @map("daily_minutes")
  /// Plan is active (in-progress) vs archived (exam passed / abandoned).
  status          StudyPlanStatus @default(active)
  /// Optional user-set target score (e.g. 80 for "I want at least 80%").
  targetScore     Int?     @map("target_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, certificationId, status], name: "one_active_plan_per_user_cert")
  @@index([userId, status])
  @@index([examDate])
  @@map("study_plans")
}

enum StudyPlanStatus {
  active
  completed
  archived
}
